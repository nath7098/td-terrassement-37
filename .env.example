# Google Search Console — coller le code fourni lors de la vérification du site
# https://search.google.com/search-console → Ajouter une propriété → Balise HTML
NUXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Exemple :
# NUXT_PUBLIC_GOOGLE_SITE_VERIFICATION=abc123XYZ_votre_code_ici

# EmailJS — clé publique du compte EmailJS
# https://dashboard.emailjs.com/admin/account → Public Key
# SERVICE_ID  = service_terrassement  (hardcodé dans contact.vue)
# TEMPLATE_ID = template_td_benne_37  (hardcodé dans contact.vue)
NUXT_PUBLIC_EMAILJS_PUBLIC_KEY=
